# SafeEye — zero config required!
# Just run: docker compose up -d
# A master token will be auto-generated on first run.

# Optional: set your own master token
# SCAN_API_MASTER_TOKEN=your_token_here

# Optional: change port (default: 1985)
# SCAN_PORT=1985

# Optional: enable cloud providers (all local providers work without any keys)
# SIGHTENGINE_API_USER=
# SIGHTENGINE_API_SECRET=
# GOOGLE_VISION_CREDENTIALS=/path/to/service-account.json
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AZURE_CONTENT_SAFETY_KEY=
# PICPURIFY_API_KEY=
# MODERATECONTENT_API_KEY=
# HF_API_TOKEN=
