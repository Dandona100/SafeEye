# SafeEye Configuration

# Master token for admin operations (required)
SCAN_API_MASTER_TOKEN=generate_a_random_token_here

# Server port (default: 1985)
SCAN_PORT=1985

# Sightengine (sign up at https://sightengine.com - free: 2,000/month)
# SIGHTENGINE_API_USER=your_user_id
# SIGHTENGINE_API_SECRET=your_secret

# Google Vision (requires GCP project + service account)
# GOOGLE_VISION_CREDENTIALS=/path/to/service-account.json

# AWS Rekognition
# AWS_ACCESS_KEY_ID=your_key
# AWS_SECRET_ACCESS_KEY=your_secret

# AWS_DEFAULT_REGION=us-east-1

# Azure Content Safety
# AZURE_CONTENT_SAFETY_KEY=your_key
# AZURE_CONTENT_SAFETY_ENDPOINT=https://your-resource.cognitiveservices.azure.com

# PicPurify
# PICPURIFY_API_KEY=your_key

# ModerateContent
# MODERATECONTENT_API_KEY=your_key

# Hugging Face (for CLIP zero-shot)
# HF_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# NSFWJS model path (download separately)
# NSFWJS_MODEL_PATH=/app/models/nsfwjs/model.onnx

# Auto-update domain blocklist
NSFW_BLOCKLIST_AUTO_UPDATE=false

# Log level
LOG_LEVEL=INFO
